generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}
enum CheckpointKey {
  SETUP
  TOPIC
  RESEARCH
  WRITE
}
enum TopicOrigin {
  USER
  SUGGESTED
}
enum InterestLevel {
  HIGH
  MEDIUM
  LOW
  DISCARDED
  UNRATED
}
enum AnnotationKind {
  HIGHLIGHT
  COMMENT
  BOOKMARK
}
enum CitationStyle {
  MLA
  APA
  CHICAGO
}
enum EventType {
  CHECKPOINT_DEADLINE
  SUBMISSION_DUE
  CUSTOM
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  createdAt     DateTime  @default(now())
}

model Account {
  id String @id @default(cuid())
  userId String
  type String
  provider String
  providerAccountId String
  refresh_token String? @db.Text
  access_token String? @db.Text
  expires_at Int?
  token_type String?
  scope String?
  id_token String? @db.Text
  session_state String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id String @id @default(cuid())
  sessionToken String @unique
  userId String
  expires DateTime
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token String @unique
  expires DateTime
  @@unique([identifier, token])
}

model Project {
  id String @id @default(cuid())
  userId String
  title String
  description String @default("")
  status ProjectStatus @default(ACTIVE)
  selectedTopicId String? @unique
  citationStyle CitationStyle @default(MLA)
  furthestCheckpoint CheckpointKey @default(SETUP)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  selectedTopic TopicIdea? @relation("SelectedTopic", fields: [selectedTopicId], references: [id], onDelete: SetNull)
  tags ProjectTag[]
  topics TopicIdea[] @relation("ProjectTopics")
  sources Source[]
  document Document?
  events CalendarEvent[]
  checkpoints CheckpointProgress[]
}

model Tag {
  id String @id @default(cuid())
  slug String @unique
  label String
  projects ProjectTag[]
}

model ProjectTag {
  projectId String
  tagId String
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([projectId, tagId])
}

model CheckpointProgress {
  id String @id @default(cuid())
  projectId String
  key CheckpointKey
  completedAt DateTime?
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@unique([projectId, key])
}

model TopicIdea {
  id String @id @default(cuid())
  projectId String
  text String
  origin TopicOrigin @default(USER)
  interest InterestLevel @default(UNRATED)
  createdAt DateTime @default(now())
  project Project @relation("ProjectTopics", fields: [projectId], references: [id], onDelete: Cascade)
  selectedBy Project? @relation("SelectedTopic")
}

model Source {
  id String @id @default(cuid())
  projectId String
  url String
  title String
  publisher String?
  author String?
  publishedAt DateTime?
  accessedAt DateTime @default(now())
  contentHtml String @db.Text
  contentText String @db.Text
  credibilityScore Int
  credibilityReasons Json
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  annotations Annotation[]
  quotes Quote[]
  citations Citation[]
}

model Annotation {
  id String @id @default(cuid())
  sourceId String
  kind AnnotationKind
  color String?
  text String?
  note String?
  anchor Json
  createdAt DateTime @default(now())
  source Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

model Quote {
  id String @id @default(cuid())
  sourceId String
  text String @db.Text
  locator String?
  anchor Json?
  createdAt DateTime @default(now())
  source Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

model Document {
  id String @id @default(cuid())
  projectId String @unique
  content Json
  plainText String @db.Text
  worksCitedOverrides Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  citations Citation[]
}

model Citation {
  id String @id @default(cuid())
  documentId String
  sourceId String
  locator String?
  renderedText String
  createdAt DateTime @default(now())
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  source Source @relation(fields: [sourceId], references: [id], onDelete: Restrict)
}

model CalendarEvent {
  id String @id @default(cuid())
  projectId String
  type EventType
  checkpoint CheckpointKey?
  title String
  dueAt DateTime
  completedAt DateTime?
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
